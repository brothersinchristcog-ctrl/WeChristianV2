rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user logged in?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Is this the user's own document?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- COLLECTIONS ---

    // 1. Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isOwner(userId) || !exists(/databases/$(database)/documents/users/$(userId)));
    }


    // 2. Daily Promises & Videos (Publicly readable by members)
    match /dailyPromises/{promiseId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only via Admin Portal (TBD)
    }
    match /dailyVideos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // 3. Events (RSVP count can be updated)
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }

    // 4. Prayer Requests
    match /prayerRequests/{reqId} {
      // Public prayers can be read by all. Private only by owner.
      allow read: if isAuthenticated() && (resource.data.type == 'public' || isOwner(resource.data.uid));
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.uid);
    }

    // 5. Announcements
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // 6. Giving Transactions (Strict privacy)
    match /givingTransactions/{txId} {
      allow read, write: if isOwner(resource.data.uid);
    }

    // 7. Broadcasts (Announcements history and Emergency meeting broadcasts)
    match /broadcasts/{broadcastId} {
      allow read, write: if isAuthenticated();
    }

    // 8. Settings (Notification settings configuration)
    match /settings/{settingId} {
      allow read, write: if isAuthenticated();
    }

    // 9. Worship Songs (Songs lyrics and offline support)
    match /worshipSongs/{songId} {
      allow read, write: if isAuthenticated();
    }
  }
}
